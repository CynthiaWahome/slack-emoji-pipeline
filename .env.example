# 🤖 SLACK EMOJI ENGINE CONFIGURATION

# [REQUIRED] Your Slack workspace domain (e.g., 'mycompany' for mycompany.slack.com)
SLACK_WORKSPACE=thecycyplayground

# [OPTIONAL] Namespace configuration for Stage 2 (Renaming)
# Emojis will be saved as {PREFIX}{human_name}{SUFFIX}
NAMESPACE_PREFIX=cy_
NAMESPACE_SUFFIX=

# [REQUIRED] Target resolution for Slack emojis (Standard is 128)
TARGET_RESOLUTION=128

# [REQUIRED] Remove white background from opaque images (true/false)
REMOVE_WHITE_BG=true

# [REQUIRED] Luminance threshold for white removal (Standard is 240)
# Pixels with R,G,B values greater than this will be removed.
WHITE_THRESHOLD=240

# [OPTIONAL] Comma-separated list of assets to protect from transparency removal
# Use this for logos where white is intentional (e.g., cy_codeit,cy_300)

# [REQUIRED] Delay in seconds between robot clicks to prevent Slack rate-limiting
UPLOAD_DELAY_SECONDS=2.0
