# 🤖 SLACK EMOJI PIPELINE CONFIGURATION

# [REQUIRED] Your Slack workspace domain (e.g. 'mycompany' for mycompany.slack.com)
SLACK_WORKSPACE=thecycyplayground

# [OPTIONAL] Namespace configuration for Stage 2 (Renaming)
# Emojis will be saved as {PREFIX}{human_name}{MIDDLE}{SUFFIX}
NAMESPACE_PREFIX=cy_
NAMESPACE_MIDDLE=
NAMESPACE_SUFFIX=

# [OPTIONAL] Manual browser path overrides (leave empty for auto-detection)
# OS Priority: Brave -> Chrome -> Edge -> Chromium
BROWSER_EXECUTABLE=
BROWSER_PROFILE_DIR=

# [OPTIONAL] Comma-separated list of assets to skip during upload
EXCLUDE_ASSETS=

# [REQUIRED] Target resolution and white-removal threshold
TARGET_RESOLUTION=128
WHITE_THRESHOLD=240
REMOVE_WHITE_BG=true

# [REQUIRED] Delay in seconds between upload actions to prevent UI rate-limiting
UPLOAD_DELAY_SECONDS=2.0
